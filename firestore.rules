rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fonction pour vérifier si l'utilisateur est authentifié
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Fonction pour vérifier si l'utilisateur est propriétaire
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Fonction pour vérifier le rôle admin
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager'];
    }
    
    // Fonction pour vérifier le rôle client
    function isClient() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'client';
    }
    
    // Fonction pour valider les données utilisateur
    function isValidUserData() {
      let data = request.resource.data;
      return data.keys().hasAll(['email', 'role', 'firstName', 'lastName']) &&
             data.role in ['visitor', 'client', 'admin', 'manager'] &&
             data.email is string &&
             data.firstName is string &&
             data.lastName is string;
    }
    
    // Règles pour la collection users
    match /users/{userId} {
      // Lecture : propriétaire, ou admin peut lire tous les utilisateurs
      allow read: if isOwner(userId) || isAdmin();
      
      // Liste tous les utilisateurs : seulement admin
      allow list: if isAdmin();
      
      // Création : seulement lors de l'inscription
      // Exception : permet la création d'un admin si l'email est admin@pharrellphone.com
      allow create: if (isOwner(userId) && 
                       isValidUserData() && 
                       request.resource.data.role in ['client', 'visitor']) ||
                       (isOwner(userId) && 
                       request.resource.data.email == 'admin@pharrellphone.com' &&
                       request.resource.data.role == 'admin');
      
      // Mise à jour : propriétaire pour ses données, admin pour tout
      allow update: if (isOwner(userId) && 
                        (!('role' in request.resource.data.diff(resource.data).changedKeys()) || 
                         request.resource.data.role == resource.data.role)) ||
                       isAdmin();
      
      // Suppression : seulement admin
      allow delete: if isAdmin();
      
      // Sous-collection addresses
      match /addresses/{addressId} {
        // Lecture : propriétaire ou admin
        allow read: if isOwner(userId) || isAdmin();
        
        // Création : propriétaire uniquement
        allow create: if isOwner(userId);
        
        // Mise à jour : propriétaire uniquement
        allow update: if isOwner(userId);
        
        // Suppression : propriétaire ou admin
        allow delete: if isOwner(userId) || isAdmin();
      }
    }
    
    // Règles pour la collection products
    match /products/{productId} {
      // Lecture : public (tous peuvent voir le catalogue)
      allow read: if true;
      
      // Écriture : admin OU utilisateur authentifié pour le seeding initial
      // Note: En production, restreindre à isAdmin() uniquement
      allow write: if isAdmin() || isAuthenticated();
    }
    
    // Règles pour la collection categories
    match /categories/{categoryId} {
      // Lecture : public (tous peuvent voir les catégories)
      allow read: if true;
      
      // Écriture : admin OU utilisateur authentifié pour le seeding initial
      // Note: En production, restreindre à isAdmin() uniquement
      allow write: if isAdmin() || isAuthenticated();
    }
    
    // Règles pour la collection orders
    match /orders/{orderId} {
      // Lecture : propriétaire de la commande ou admin (admins peuvent lire toutes les commandes)
      allow read: if isOwner(resource.data.userId) || isAdmin();
      
      // Création : seulement clients pour eux-mêmes
      allow create: if isClient() && 
                       isOwner(request.resource.data.userId) &&
                       request.resource.data.keys().hasAll(['userId', 'items', 'totalAmount', 'status', 'createdAt']);
      
      // Mise à jour : admin seulement (pour changer le statut)
      allow update: if isAdmin();
      
      // Suppression : seulement admin
      allow delete: if isAdmin();
    }
    
    // Règles pour la collection promotions
    match /promotions/{promotionId} {
      // Lecture : public (tous peuvent voir les promotions)
      allow read: if true;
      
      // Écriture : seulement admin
      allow write: if isAdmin();
    }
    
    // Règles pour la collection reviews
    match /reviews/{reviewId} {
      // Lecture : public (tous peuvent voir les avis)
      allow read: if true;
      
      // Création : tout utilisateur authentifié peut créer un avis
      allow create: if isAuthenticated() && 
                       isOwner(request.resource.data.userId);
      
      // Mise à jour : propriétaire ou admin
      allow update: if isOwner(resource.data.userId) || isAdmin();
      
      // Suppression : propriétaire ou admin
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }
    
    // Règles pour la collection notifications
    match /notifications/{notificationId} {
      // Lecture : destinataire ou admin
      allow read: if isOwner(resource.data.userId) || isAdmin();
      
      // Création : seulement admin
      allow create: if isAdmin();
      
      // Mise à jour : destinataire (pour marquer comme lu) ou admin
      allow update: if (isOwner(resource.data.userId) && 
                        request.resource.data.diff(resource.data).changedKeys().hasOnly(['isRead'])) ||
                       isAdmin();
      
      // Suppression : seulement admin
      allow delete: if isAdmin();
    }
    
    // Règles pour les logs de sécurité (écriture seulement)
    match /security_logs/{logId} {
      // Pas de lecture (sensible)
      allow read: if false;
      
      // Création : utilisateurs authentifiés seulement
      allow create: if isAuthenticated();
      
      // Pas de mise à jour ou suppression
      allow update, delete: if false;
    }
    
    // Règles pour les logs d'application (écriture seulement)
    match /app_logs/{logId} {
      // Lecture : seulement admin
      allow read: if isAdmin();
      
      // Création : utilisateurs authentifiés seulement
      allow create: if isAuthenticated();
      
      // Pas de mise à jour ou suppression
      allow update, delete: if false;
    }
    
    // Règles pour la collection audit_logs
    match /audit_logs/{logId} {
      // Lecture : seulement admin
      allow read: if isAdmin();
      
      // Création : seulement admin
      allow create: if isAdmin();
      
      // Pas de mise à jour ou suppression (immutable)
      allow update, delete: if false;
    }
    
    // Règles pour la collection stock_movements
    match /stock_movements/{movementId} {
      // Lecture : seulement admin
      allow read: if isAdmin();
      
      // Création : seulement admin
      allow create: if isAdmin();
      
      // Mise à jour et suppression : seulement admin
      allow update, delete: if isAdmin();
    }
    
    // Règles pour la collection suppliers (fournisseurs)
    match /suppliers/{supplierId} {
      // Lecture : seulement admin
      allow read: if isAdmin();
      
      // Création : seulement admin
      allow create: if isAdmin();
      
      // Mise à jour : seulement admin
      allow update: if isAdmin();
      
      // Suppression : seulement admin
      allow delete: if isAdmin();
    }
    
    // Règles pour la collection two_factor_codes (codes de vérification 2FA)
    // Aucun accès client direct : tout passe par les Cloud Functions
    // sendTwoFactorCode / verifyTwoFactorCode (droits admin).
    match /two_factor_codes/{userId} {
      allow read, write: if false;
    }
    
    // Règles par défaut : tout refuser
    match /{document=**} {
      allow read, write: if false;
    }
  }
}