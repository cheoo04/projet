<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme de lancement pour Android 12+ -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <!-- Couleur de fond -->
        <!-- Icône animée -->
        <!-- Couleur de fond de l'icône -->
        <!-- Durée de l'animation (millisecondes) -->
        <item name="android:windowSplashScreenAnimationDuration">1000</item>
        <!-- Autres options -->
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:windowSplashScreenBackground">#7C3BAE</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/android12splash</item>
        <item name="android:windowSplashScreenIconBackgroundColor">#7C3BAE</item>
    </style>
    <!-- Theme normal de l'app -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
